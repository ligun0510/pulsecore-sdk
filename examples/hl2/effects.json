{
  "schema_version": 1,
  "_version_note": "pack_version is what the app compares against the catalogue to decide an update.",
  "pack_version": 2,
  "rules": [
    { "when": { "state": "weapon.current", "equals": "weapon_pistol" },
      "apply": { "right_trigger": { "preset": "pistol" } } },
    { "when": { "state": "weapon.current", "equals": "weapon_357" },
      "apply": { "right_trigger": { "preset": "revolver" } } },
    { "when": { "state": "weapon.current", "equals": "weapon_smg1" },
      "apply": { "right_trigger": { "preset": "smg" } } },
    { "when": { "state": "weapon.current", "equals": "weapon_ar2" },
      "apply": { "right_trigger": { "preset": "assault_rifle" } } },
    { "when": { "state": "weapon.current", "equals": "weapon_shotgun" },
      "apply": { "right_trigger": { "preset": "heavy_shotgun" } } },
    { "when": { "state": "weapon.current", "equals": "weapon_crossbow" },
      "apply": { "right_trigger": { "preset": "crossbow" } } },
    { "when": { "state": "weapon.current", "equals": "weapon_physcannon" },
      "apply": { "right_trigger": { "preset": "gravity_weapon" } } },
    { "on_event": "weapon.primary_fire",
      "apply": { "haptic": { "preset": "weapon_recoil", "intensity": 0.8 } } },
    { "when": { "state": "vehicle.current", "equals": "airboat" },
      "apply": { "right_trigger": { "preset": "vehicle_accelerator" },
                 "left_trigger": { "preset": "vehicle_brake" } } },
    { "when": { "state": "weapon.reloading", "equals": "true" },
      "apply": { "right_trigger": { "preset": "reload_locked" } } },

    { "_comment": "Sustained levels: held while the state holds, released the moment it stops.",
      "when": { "state": "vehicle.current", "equals": "airboat" },
      "apply": { "rumble": { "heavy": 120, "light": 55,
                             "scale_by": { "value": "vehicle.speed", "min": 0, "max": 450 } } } },
    { "when": { "state": "player.medium", "equals": "water" },
      "apply": { "rumble": { "heavy": 45, "light": 25 } } },


    { "_comment": "The pad's colour IS the health bar. Green at full, through amber, to red as it",
      "_comment2": "falls -- read at a glance without looking away from the game. Scale is inverted",
      "_comment3": "(100 -> 0) so the colour travels toward red as health drops.",
      "when": { "state": "game.state", "equals": "playing" },
      "apply": { "lightbar": { "r": 20, "g": 220, "b": 40,
                               "to": { "r": 255, "g": 0, "b": 0 },
                               "scale_by": { "value": "player.health", "min": 100, "max": 0 } } } },

    { "_comment": "Heartbeat. The BEAT never changes; the GAP shrinks as health falls, which is what",
      "_comment2": "makes it read as a pulse quickening rather than a metronome getting louder.",
      "_comment3": "interval_scale_by is inverted (100 -> 25) so LESS health means a FASTER heart.",
      "when": { "state": "player.critical", "equals": "true" },
      "apply": { "pulse_train": { "heavy": 150, "light": 40, "beat_ms": 70, "interval_ms": 1400,
                                  "interval_scale_by": { "value": "player.health",
                                                         "min": 100, "max": 25 } } } },

    { "_comment": "Footsteps by material. The mod reports what the movement code already resolved,",
      "_comment2": "so these are the real surface properties, not a guess from the sound.",
      "when": { "state": "player.ground_material", "equals": "metal" },
      "apply": { "rumble": { "heavy": 22, "light": 14 } } },
    { "when": { "state": "player.ground_material", "equals": "grate" },
      "apply": { "rumble": { "heavy": 16, "light": 26 } } },
    { "when": { "state": "player.ground_material", "equals": "concrete" },
      "apply": { "rumble": { "heavy": 14, "light": 6 } } },
    { "_comment": "A ladder is RUNGS, not a buzz: alternating beats read as left hand, right hand.",
      "when": { "state": "player.medium", "equals": "ladder" },
      "apply": { "pulse_train": { "heavy": 70, "light": 70, "beat_ms": 45, "interval_ms": 320,
                                  "alternate": true } } },
    { "on_event": "player.water_enter",
      "apply": { "haptic": { "heavy": 150, "light": 90, "duration_ms": 180 } } },
    { "_comment": "A stumble off a kerb and a two-storey drop are the same EVENT; only the number",
      "_comment2": "tells them apart, so the thump is scaled by the speed it happened at.",
      "on_event": "player.landed",
      "apply": { "haptic": { "heavy": 230, "light": 90, "duration_ms": 140,
                             "scale_by": { "value": "player.land_speed", "min": 150, "max": 900 } } } },

    { "_comment": "Half-Life 2's OWN rumble bus, forwarded by the mod. Valve already decided what each",
      "_comment3": "of these should feel like; we only choose how a DualSense expresses it.",
      "on_event": "hl2.rumble.crowbar_swing",
      "apply": { "haptic": { "heavy": 120, "light": 180, "duration_ms": 90 } } },
    { "on_event": "hl2.rumble.shotgun_double",
      "apply": { "haptic": { "heavy": 255, "light": 200, "duration_ms": 180 } } },
    { "on_event": "hl2.rumble.physcannon_punt",
      "apply": { "haptic": { "heavy": 230, "light": 120, "duration_ms": 140 } } },
    { "on_event": "hl2.rumble.fall_long",
      "apply": { "haptic": { "heavy": 255, "light": 110, "duration_ms": 220 } } },
    { "_comment": "The engine now RISES WITH SPEED instead of being one fixed hum.",
      "when": { "state": "hl2.rumble.loop", "equals": "jeep_engine" },
      "apply": { "rumble": { "heavy": 110, "light": 45,
                             "scale_by": { "value": "vehicle.speed", "min": 0, "max": 500 } } } },

    { "_comment": "Gravity gun. The faint electric tremor while something is held, and the punt.",
      "_comment2": "The tremor now grows with the object's MASS: a can barely buzzes, a filing",
      "_comment3": "cabinet is felt -- and the trigger pushes back in proportion to the weight.",
      "when": { "state": "physcannon.holding", "equals": "true" },
      "apply": { "rumble": { "heavy": 40, "light": 60,
                             "scale_by": { "value": "physcannon.mass", "min": 5, "max": 250 } },
                 "right_trigger": { "resistance": { "position": 2, "strength": 8,
                             "scale_by": { "value": "physcannon.mass", "min": 5, "max": 250 } } } } },
    { "on_event": "weapon.reload_step",
      "apply": { "haptic": { "heavy": 60, "light": 190, "duration_ms": 55 } } },
    { "on_event": "weapon.reload_start",
      "apply": { "haptic": { "heavy": 120, "light": 80, "duration_ms": 90 } } },
    { "on_event": "grenade.thrown",
      "apply": { "haptic": { "heavy": 100, "light": 140, "duration_ms": 70 } } }
  ]
}
